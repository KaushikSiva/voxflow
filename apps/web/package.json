{
  "name": "voxflow-web",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "sync": "svelte-kit sync",
    "dev": "svelte-kit sync && vite dev --host 0.0.0.0 --port 5173",
    "build": "svelte-kit sync && vite build",
    "preview": "vite preview",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "test": "vitest run"
  },
  "devDependencies": {
    "@sveltejs/adapter-auto": "^3.2.5",
    "@sveltejs/kit": "^2.16.0",
    "@sveltejs/vite-plugin-svelte": "^5.0.0",
    "@types/node": "^22.13.8",
    "svelte": "^5.20.2",
    "svelte-check": "^4.1.4",
    "typescript": "^5.7.3",
    "vite": "^6.2.0",
    "vitest": "^3.0.8"
  }
}
